# Best-bet live sponsor path on Base Sepolia:
# 1. Run `bun run wallet:base-sepolia` to generate a burner wallet
# 2. Use the printed private key for FRONTIER_ERC8004_PRIVATE_KEY
# 3. Use the printed address for FRONTIER_PAYWALL_RECIPIENT
# 4. Fund that address with Base Sepolia ETH
# 5. Set FRONTIER_FACILITATOR_URL=https://x402.org/facilitator
# 6. Use the same Base Sepolia RPC for both ERC-8004 and x402 settlement verification

FRONTIER_ERC8004_ENABLED=false
FRONTIER_ERC8004_TESTNET=true
FRONTIER_ERC8004_RPC_URL=https://sepolia.base.org
FRONTIER_ERC8004_PRIVATE_KEY=
FRONTIER_ERC8004_EXPLORER_BASE_URL=https://sepolia.basescan.org
