DATABASE_URL=postgresql://user:password@localhost:5432/plgenesis
GOOGLE_API_KEY=
# Optional alias if you prefer this name:
# GEMINI_API_KEY=

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_FRONTIER_VERIDEX_NETWORK=testnet
NEXT_PUBLIC_FRONTIER_RELAYER_URL=

FRONTIER_VERIDEX_NETWORK=testnet
FRONTIER_MODE=hybrid
FRONTIER_RELAYER_URL=
# Optional. Leave blank if your relayer accepts unsigned public traffic.
FRONTIER_RELAYER_API_KEY=

# Best-bet live sponsor path on Base Sepolia:
# 1. Set FRONTIER_RELAYER_URL to your live relayer.
# 2. Authenticate once in the app so the runtime can derive a live enterprise session.
# 3. Optional: run `bun run wallet:base-sepolia` if you want a dedicated ERC-8004 signer key.
# 4. Use the printed private key for FRONTIER_ERC8004_PRIVATE_KEY and the address for FRONTIER_PAYWALL_RECIPIENT.
# 5. Fund the dedicated signer only if you use the private-key route for ERC-8004 writes.
# 6. Set FRONTIER_FACILITATOR_URL=https://x402.org/facilitator.
# 7. Use the same Base Sepolia RPC for both ERC-8004 and x402 settlement verification.

FRONTIER_ERC8004_ENABLED=false
FRONTIER_ERC8004_TESTNET=true
FRONTIER_ERC8004_RPC_URL=https://sepolia.base.org
# Optional if you want a dedicated onchain signer. If blank, FrontierGuard will
# use the authenticated enterprise session signer for live ERC-8004 writes.
FRONTIER_ERC8004_PRIVATE_KEY=
FRONTIER_ERC8004_EXPLORER_BASE_URL=https://sepolia.basescan.org
FRONTIER_PAYWALL_RPC_URL=https://sepolia.base.org
FRONTIER_PAYWALL_EXPLORER_BASE_URL=https://sepolia.basescan.org
FRONTIER_PAYWALL_NETWORK=base-sepolia
FRONTIER_PAYWALL_RECIPIENT=
FRONTIER_FACILITATOR_URL=
FRONTIER_FACILITATOR_FALLBACK_URL=

FRONTIER_PINATA_GATEWAY=
FRONTIER_PINATA_API_KEY=

STORACHA_AGENT_KEY=
STORACHA_PROOF=
STORACHA_SPACE_DID=

NEXT_PUBLIC_FLOW_NETWORK=testnet
NEXT_PUBLIC_FLOW_FCL_ACCESS_NODE=
NEXT_PUBLIC_FLOW_WALLET_DISCOVERY=
NEXT_PUBLIC_FLOW_EVM_RPC_URL=
NEXT_PUBLIC_FLOW_EVM_CHAIN_ID=
FRONTIER_FLOW_ENABLED=false
FRONTIER_FLOW_SERVICE_ACCOUNT_ADDRESS=
FRONTIER_FLOW_SERVICE_ACCOUNT_PRIVATE_KEY=
FRONTIER_FLOW_SERVICE_ACCOUNT_KEY_INDEX=
FRONTIER_FLOW_SCHEDULER_CONTRACT_ADDRESS=
FRONTIER_FLOW_TRANSACTION_HANDLER_ADDRESS=

